# Copy to .env / Vercel project env — never commit secrets

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
RESEND_API_KEY=re_xxx
SENDER_EMAIL=Verdex <no-reply@verdexswap.site>
SITE_URL=https://verdexswap.site

# Comma-separated server-side administrator allow-list. When set, it is
# authoritative over the legacy database list; never put this in client code.
VERDEX_ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Mainnet only — leave disabled until audited validator infrastructure exists.
VERDEX_MAINNET_ENABLED=false
VERDEX_MAINNET_RELEASE_APPROVED=false
VERDEX_MAINNET_CHAIN_ID=
VERDEX_MAINNET_GENESIS_HASH=
VERDEX_MAINNET_PROTOCOL_VERSION=
VERDEX_MAINNET_ASSET_MODEL=
VDX_RPC_URL=
VERDEX_MAINNET_EXPLORER_URL=
# Required only when VERDEX_MAINNET_ASSET_MODEL=prc20.
VDX_MAINNET_VDX_ADDRESS=
VDX_MAINNET_VDX_SYMBOL=VDX
VDX_MAINNET_VDX_DECIMALS=18
# SHA-256 of the exact deployed runtime bytecode (hex without 0x). Pinning it
# prevents a look-alike contract or an unexpected proxy implementation from
# satisfying the website's release check.
VDX_MAINNET_VDX_RUNTIME_CODE_SHA256=
# Optional audited mainnet utility-token contract. Leave blank to hide VDXU.
VDX_MAINNET_VDXU_ADDRESS=
VDX_MAINNET_VDXU_RUNTIME_CODE_SHA256=
VDX_ESCROW_CONTRACT_ADDRESS=
VDX_ESCROW_RUNTIME_CODE_SHA256=
# Trade attestor EIP-712 signing key (secp256k1, 0x + 64 hex). The
# corresponding address MUST hold TRADE_ATTESTOR_ROLE on the deployed escrow.
# Leave blank to operate P2P in coordination-only mode (no on-chain escrow).
TRADE_ATTESTOR_PRIVATE_KEY=
# Custodial wallet master key (32 bytes, base64 or hex). Used to encrypt the
# HD seed that derives all user deposit addresses. NEVER commit this.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WALLET_MASTER_KEY=
# Keep false until the hardened raw-transaction client flow is independently verified.
VERDEX_MAINNET_PUBLIC_BROADCAST_ENABLED=false

# Release-evidence verifier trust roots. These are public Ed25519 SPKI DER
# values encoded as base64, established by the board out of band. Never enter
# a private key, seed phrase, HSM credential, or Safe owner key here.
VERDEX_TRUSTED_GENESIS_ED25519_PUBLIC_KEY=
VERDEX_TRUSTED_AUDITOR_ED25519_PUBLIC_KEY=
VERDEX_TRUSTED_COMPLIANCE_ED25519_PUBLIC_KEY=
