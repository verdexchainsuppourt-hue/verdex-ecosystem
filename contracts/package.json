{
  "name": "@verdex/contracts",
  "version": "2.0.0",
  "description": "Verdex PRC20 + Phase 4 AMM (Factory, Pair, Router, Aggregator) — 0.25% fee",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
