MAINNET_GOVERNANCE_MULTISIG_THRESHOLD=TO_BE_PROVIDED_DURING_DEPLOYMENT_SAFE_THRESHOLD

# P2P roles must belong to separate real operators, not the deployer.
MAINNET_ARBITERS=TO_BE_PROVIDED_DURING_DEPLOYMENT_ARBITER_1,TO_BE_PROVIDED_DURING_DEPLOYMENT_ARBITER_2,TO_BE_PROVIDED_DURING_DEPLOYMENT_ARBITER_3
