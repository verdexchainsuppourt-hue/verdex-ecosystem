# DO NOT COMMIT A FILLED COPY. Store it only in the deployment ceremony's
# ephemeral secret manager / reviewed CI environment.
# Every TO_BE_PROVIDED_DURING_DEPLOYMENT value is a hard deployment blocker.

MAINNET_DEPLOY_APPROVED=TO_BE_PROVIDED_DURING_DEPLOYMENT_AFTER_BOARD_SIGNOFF

# Chain identity generated from the QBFT ceremony output.
VDX_RPC_URL=TO_BE_PROVIDED_DURING_DEPLOYMENT_PUBLIC_OR_PRIVATE_DEPLOYMENT_RPC
VERDEX_MAINNET_CHAIN_ID=TO_BE_PROVIDED_DURING_DEPLOYMENT_UNIQUE_CHAIN_ID
