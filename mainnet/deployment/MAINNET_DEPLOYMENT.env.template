VERDEX_MAINNET_PROTOCOL_VERSION=TO_BE_PROVIDED_DURING_DEPLOYMENT_REVIEWED_RELEASE_ID

# The deployer signing path is supplied only to the isolated deployment runner.
# Never paste a seed phrase or private key into Git, Vercel, APKs, website code,
# issue trackers, chat, or this template.
PRIVATE_KEY=TO_BE_PROVIDED_DURING_DEPLOYMENT_EPHEMERAL_DEPLOYER_SIGNER

# Existing, independently controlled custody/governance configuration.
MAINNET_GENESIS_VAULT=TO_BE_PROVIDED_DURING_DEPLOYMENT_CONTRACT_BACKED_VAULT
